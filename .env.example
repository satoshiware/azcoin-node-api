APP_ENV=dev
PORT=8080
API_V1_PREFIX=/v1
LOG_LEVEL=INFO

# Auth (stub)
# AUTH_MODE defaults to `dev_token` in dev and `jwt` in prod.
# Protected routes (currently `/v1/az/*`, `/v1/btc/*`, `/v1/tx/*`) require:
#   Authorization: Bearer <token>
AUTH_MODE=dev_token
AZ_API_DEV_TOKEN=replace-me

# AZCoin RPC (used by `/v1/az/*`)
AZ_RPC_URL=http://127.0.0.1:19332
AZ_RPC_USER=replace-me
AZ_RPC_PASSWORD=replace-me
AZ_RPC_TIMEOUT_SECONDS=5

# Bitcoin RPC (used by `/v1/btc/*`)
BTC_RPC_URL=http://127.0.0.1:8332
BTC_RPC_USER=replace-me
BTC_RPC_PASSWORD=replace-me
BTC_RPC_TIMEOUT_SECONDS=5

# Docker (optional)
# Core image used by `docker-compose.yml`
AZCOIN_CORE_IMAGE=ghcr.io/satoshiware/azcoin-node:latest
# Core RPC port (container/network only; not published to host)
AZ_RPC_PORT=19332

# Bitcoin core image used by `docker-compose.yml`
BITCOIN_CORE_IMAGE=bitcoin/bitcoin-core:28.0
# Bitcoin RPC port (container/network only; not published to host)
BTC_RPC_PORT=8332
